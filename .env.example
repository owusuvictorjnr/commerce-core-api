# Copy this file to .env and fill in real secrets locally.
# .env is ignored by git.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=commerce_core_api

PORT=4000
NODE_ENV=production

# App database URL (used by Prisma and API runtime)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
