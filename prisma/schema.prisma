// Prisma 7 datasource connection is configured in prisma.config.ts.
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Order {
  id        Int      @id @default(autoincrement())
  tenantId  String
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}
